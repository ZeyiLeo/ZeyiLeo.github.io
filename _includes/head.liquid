<!DOCTYPE html>
<html lang="{{ page.lang | default: site.lang | default: 'en' }}">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{{ page.title | default: site.title }}</title>

  {% if page.redirect %}
    {% if page.redirect == true %}
      {% assign redirect = site.baseurl | append: '/' %}
    {% elsif page.redirect contains '://' %}
      {% assign redirect = page.redirect %}
    {% else %}
      {% assign redirect = page.redirect | relative_url %}
    {% endif %}
    <meta http-equiv="refresh" content="3; url={{ redirect }}">
  {% endif %}

  {% include head %}
  
  <!-- AOS 动画 CSS -->
  <link
    rel="stylesheet"
    href="https://cdn.jsdelivr.net/npm/aos@2.3.4/dist/aos.css"
  />
  
  <style>
    /* Apple 风格简洁设计基础样式示例 */
    body {
      font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Oxygen,
        Ubuntu, Cantarell, "Open Sans", "Helvetica Neue", sans-serif;
      background: #f5f7fa;
      color: #1d1d1f;
      line-height: 1.6;
      margin: 0;
      padding: 0;
    }
    header {
      background: #fff;
      box-shadow: 0 1px 3px rgb(0 0 0 / 0.1);
      padding: 1rem 2rem;
      display: flex;
      align-items: center;
      justify-content: space-between;
      position: sticky;
      top: 0;
      z-index: 100;
    }
    header .logo {
      font-weight: 700;
      font-size: 1.5rem;
      color: #0071e3; /* Apple 蓝 */
      user-select: none;
    }
    nav a {
      color: #1d1d1f;
      margin-left: 1.5rem;
      text-decoration: none;
      font-weight: 500;
      transition: color 0.3s ease;
    }
    nav a:hover {
      color: #0071e3;
    }
    main {
      max-width: 900px;
      margin: 2rem auto;
      padding: 0 1rem;
    }
    footer {
      text-align: center;
      padding: 1rem;
      color: #6e6e73;
      font-size: 0.9rem;
      border-top: 1px solid #e1e1e1;
      margin-top: 3rem;
    }
  </style>
</head>

<body>
  <header data-aos="fade-down" data-aos-duration="800">
    <div class="logo">{{ site.title }}</div>
    <nav>
      <a href="{{ '/' | relative_url }}">Home</a>
      <a href="{{ '/about/' | relative_url }}">About</a>
      <a href="{{ '/publications/' | relative_url }}">Publications</a>
      <a href="{{ '/contact/' | relative_url }}">Contact</a>
    </nav>
  </header>

  <main data-aos="fade-up" data-aos-duration="800" data-aos-delay="200">
    {{ content }}
  </main>

  <footer data-aos="fade-up" data-aos-duration="800" data-aos-delay="400">
    &copy; {{ site.time | date: '%Y' }} {{ site.author.name }}. All rights reserved.
  </footer>

  <!-- AOS 动画脚本 -->
  <script src="https://cdn.jsdelivr.net/npm/aos@2.3.4/dist/aos.js"></script>
  <script>
    AOS.init({
      once: true,
      easing: 'ease-out-cubic',
      duration: 800,
    });
  </script>
</body>
</html>
